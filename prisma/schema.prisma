generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id           Int         @id @default(autoincrement())
  name         String?
  gender       String?
  email        String      @unique
  userName     String      @unique
  password     String?
  roleId       Int?
  status       Int?
  salaryId     Int?
  keepSalaryId Int?
  salaryPlusId Int?
  keepSalary   KeepSalary? @relation(fields: [keepSalaryId], references: [id])
  role         Role?       @relation(fields: [roleId], references: [id])
  salary       Salary?     @relation(fields: [salaryId], references: [id])
  salaryPlus   SalaryPlus? @relation(fields: [salaryPlusId], references: [id])
  works        Work[]

  @@index([roleId])
  @@index([status])
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  accounts    Account[]
  permissions Permission[]
}

model Permission {
  id     Int    @id @default(autoincrement())
  url    String @unique
  roleId Int?
  role   Role?  @relation(fields: [roleId], references: [id])

  @@index([roleId])
}

model Salary {
  id       Int       @id @default(autoincrement())
  weekday  Int?
  weekend  Int?
  name     String    @unique
  accounts Account[]
}

model DeductionType {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  price            Int?
  title            String?
  deductions       Deduction[]
  salaryDeductions SalaryDeduction[]
}

model Deduction {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  price            Int?
  deductionTypeId  Int?
  deductionType    DeductionType?    @relation(fields: [deductionTypeId], references: [id])
  salaryDeductions SalaryDeduction[]
}

model Work {
  id              Int               @id @default(autoincrement())
  date            String?
  startTime       String?
  endTime         String?
  salary          String?
  isMopping       Int?
  accountId       Int?
  status          Int?
  salaryDeduction SalaryDeduction[]
  account         Account?          @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([status])
}

model SalaryDeduction {
  id              Int            @id @default(autoincrement())
  workId          Int?
  deductionTypeId Int?
  deductionId     Int?
  quantity        String?
  detail          String?
  cost            Int?
  deduction       Deduction?     @relation(fields: [deductionId], references: [id])
  deductionType   DeductionType? @relation(fields: [deductionTypeId], references: [id])
  work            Work?          @relation(fields: [workId], references: [id])

  @@index([workId])
}

model WorkError {
  id            Int     @id @default(autoincrement())
  date          String?
  workErrorType Int?
}

model KeepSalary {
  id       Int       @id @default(autoincrement())
  date     String?
  salary   String?
  status   Int?
  accounts Account[]

  @@index([status])
}

model SalaryPlus {
  id       Int       @id @default(autoincrement())
  name     String?   @unique
  plus     Int?
  accounts Account[]
}
